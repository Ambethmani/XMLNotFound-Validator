<?xml version="1.0" encoding="UTF-8"?>
<root>

  <!-- Scenario 1: Duplicate href in .cite element -->
  <a class="cite" href="ref1 ref2 ref1 ref3 ref2">Citation with duplicates</a>

  <!-- Scenario 2: Comment with double-hyphen inside (illegal in XML) -->
  <!-- This is a comment -- with a double hyphen inside it -->

  <!-- Scenario 3: Table with only th, no td -->
  <table>
    <tr>
      <th>Column A</th>
      <th>Column B</th>
    </tr>
  </table>

  <!-- Scenario 4: Various malformed and unknown named entities -->
  <p>Invalid entity with dots: &ndf..553;</p>
  <p>Long garbage entity: &hdfkhsdfb;</p>
  <p>Mixed alphanumeric mess: &hhsf88...sd;</p>
  <p>Valid entity for comparison: &amp; &lt; &gt; &nbsp;</p>

</root>
